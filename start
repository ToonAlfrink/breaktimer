#!/bin/bash

# breaktimer launcher — headless timer core + ambient layer-shell bar.
# Designed for desktop autostart (~/.config/autostart/breaktimer.desktop).
# Runs as a watchdog: restarts either process if it crashes or exits.
# Each process holds a singleton lock (breaktimer-{core,ambient}.lock in
# XDG_RUNTIME_DIR); flock -n detects whether a process is running before
# trying to start a new one, so this loop is safe to run at any interval.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/breaktimer"
mkdir -p "$LOG_DIR"

RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
SOCKET="$RUNTIME_DIR/${WAYLAND_DISPLAY:-wayland-1}"

# Wait for the Wayland session instead of a blind sleep.
for _ in $(seq 1 30); do
    [ -S "$SOCKET" ] && break
    sleep 1
done

# Start a process only if its singleton lock is free (not already running).
_ensure() {
    local name="$1" script="$2"
    flock -n "$RUNTIME_DIR/breaktimer-${name}.lock" true 2>/dev/null \
        && python3 "$SCRIPT_DIR/$script" >>"$LOG_DIR/${name}.log" 2>&1 &
}

while true; do
    _ensure core    main.py
    _ensure ambient ambient.py
    sleep 5
done
