#!/bin/bash

# breaktimer launcher — headless timer core + ambient layer-shell bar.
# Designed for desktop autostart (~/.config/autostart/breaktimer.desktop).
# Idempotent: each process holds a runtime singleton lock and exits if
# another instance is already running.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR" || exit 1

LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/breaktimer"
mkdir -p "$LOG_DIR"

# Wait for the Wayland session instead of a blind sleep.
SOCKET="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/${WAYLAND_DISPLAY:-wayland-1}"
for _ in $(seq 1 30); do
    [ -S "$SOCKET" ] && break
    sleep 1
done

python3 main.py >>"$LOG_DIR/core.log" 2>&1 &
python3 ambient.py >>"$LOG_DIR/ambient.log" 2>&1 &
