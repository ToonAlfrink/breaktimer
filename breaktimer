#!/usr/bin/env python3
"""breaktimer — control the running breaktimer session.

Commands:
  status                   print remaining time and today's work history
  url                      print the mobile status page URL (http://<LAN-IP>:8642/)
  brightness off [N] [P]   stop dimming for N minutes (default: 120), park displays at P% (default: 100)
  brightness on            resume automatic dimming
  blocklist                print the active domain blocklist (from STATE_DIR/blocklist.txt)
  restart                  restart all three systemd user services
"""
import socket
import subprocess
import sys
import os
import time

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import blocklist
import brightness_control
import main as _main
import status


def cmd_status():
    s = status.Snapshot.read(max_age_seconds=10)
    if not s:
        print("breaktimer: core not running")
        return
    active = "●" if s.is_active else "○"
    remaining = status.format_time(s.remaining_seconds)
    print(f"{remaining} {active}  {s.history}")
    rate = s.refill_rate
    if rate <= 0:
        print("day limit reached — no refill left today")
    elif rate < 1:
        print(f"past daily budget — breaks refill at {round(rate * 100)}%")
    pause_left = brightness_control.pause_until() - time.time()
    if pause_left > 0:
        print(f"brightness control off for another {status.format_time(pause_left)}")


def cmd_brightness_off(minutes=120.0, percent=100):
    brightness_control.pause(minutes * 60, percent)
    print(f"brightness control off for {minutes:g} min, displays at {percent}%")


def cmd_brightness_on():
    brightness_control.unpause()
    print("brightness control back on")


def cmd_blocklist():
    blocklist.blocklist_file = os.path.join(_main.STATE_DIR, "blocklist.txt")
    domains = blocklist.read_domains()
    if not domains:
        print(f"no domains blocked  (edit {blocklist.blocklist_file} to add some)")
        return
    print(f"{len(domains)} domain(s) blocked via {blocklist.HOSTS_PATH}:")
    for d in domains:
        if d.startswith("www."):
            print(f"  {d}  →  0.0.0.0")
        else:
            print(f"  {d}  +  www.{d}  →  0.0.0.0")


def cmd_url(port=8642):
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        ip = s.getsockname()[0]
        s.close()
    except OSError:
        ip = "localhost"
    print(f"http://{ip}:{port}/")


def cmd_restart():
    subprocess.run(
        ["systemctl", "--user", "restart",
         "breaktimer-core.service", "breaktimer-ambient.service",
         "breaktimer-web.service"],
        check=True,
    )
    print("restarted")


argv = sys.argv[1:]
if not argv or argv[0] == "status":
    cmd_status()
elif argv[0] == "url":
    cmd_url()
elif argv[0] == "brightness" and len(argv) > 1 and argv[1] == "off":
    cmd_brightness_off(
        float(argv[2]) if len(argv) > 2 else 120.0,
        int(argv[3]) if len(argv) > 3 else 100,
    )
elif argv[0] == "brightness" and len(argv) > 1 and argv[1] == "on":
    cmd_brightness_on()
elif argv[0] == "blocklist":
    cmd_blocklist()
elif argv[0] == "restart":
    cmd_restart()
else:
    print(__doc__)
    sys.exit(1)
