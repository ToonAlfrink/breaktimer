#!/usr/bin/env python3
"""breaktimer — control the running breaktimer session.

Commands:
  status                   print remaining time and today's work history
  url                      print the mobile status page URL (http://<LAN-IP>:8642/)
  brightness off [N] [P]   stop dimming for N minutes (default: 120), park displays at P% (default: 100)
  brightness on            resume automatic dimming
  blocklist                print the active domain blocklist (from STATE_DIR/blocklist.txt)
  restart                  restart all three systemd user services
"""
import socket
import subprocess
import sys
import os
import time

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import blocklist
import brightness_control
import main as _main
import status


def cmd_status():
    s = status.Snapshot.read(max_age_seconds=10)
    if not s:
        print("breaktimer: core not running")
        return
    active = "●" if s.is_active else "○"
    remaining = status.format_time(s.remaining_seconds)
    print(f"{remaining} {active}  {s.history}")
    rate = s.refill_rate
    if rate <= 0:
        print("day limit reached — no refill left today")
    elif rate < 1:
        print(f"past daily budget — breaks refill at {round(rate * 100)}%")
    pause_left = brightness_control.pause_until() - time.time()
    if pause_left > 0:
        print(f"brightness control off for another {status.format_time(pause_left)}")


def cmd_brightness_off(minutes=120.0, percent=100):
    brightness_control.pause(minutes * 60, percent)
    print(f"brightness control off for {minutes:g} min, displays at {percent}%")


def cmd_brightness_on():
    brightness_control.unpause()
    print("brightness control back on")


def cmd_blocklist():
    state_dir = _main.STATE_DIR
    blocklist.blocklist_file          = os.path.join(state_dir, "blocklist.txt")
    blocklist.blocklist_active_file   = os.path.join(state_dir, "blocklist-active.txt")
    blocklist.blocklist_strict_file   = os.path.join(state_dir, "blocklist-strict.txt")
    blocklist.blocklist_schedule_file = os.path.join(state_dir, "blocklist-schedule.txt")

    snap = status.Snapshot.read(max_age_seconds=10)
    is_active = snap.is_active if snap else False
    strict    = (snap.refill_rate <= 0) if snap else False

    def _fmt(domains):
        lines = []
        for d in domains:
            if d.startswith("www."):
                lines.append(f"    {d}  →  0.0.0.0")
            else:
                lines.append(f"    {d}  +  www.{d}  →  0.0.0.0")
        return lines

    always   = blocklist.read_domains()
    active   = blocklist.read_domains_active()
    strict_  = blocklist.read_domains_strict()
    schedule = blocklist.read_domains_schedule()

    if not (always or active or strict_ or schedule):
        print("no domains blocked")
        print(f"  always:   {blocklist.blocklist_file}")
        print(f"  active:   {blocklist.blocklist_active_file}  (blocked during work sessions)")
        print(f"  strict:   {blocklist.blocklist_strict_file}  (blocked when daily refill is gone)")
        print(f"  schedule: {blocklist.blocklist_schedule_file}  (blocked during time windows)")
        return

    if always:
        print(f"always blocked ({len(always)}):")
        print("\n".join(_fmt(always)))
    if active:
        tag = "● active now" if is_active else "○ inactive (break)"
        print(f"work-session blocked ({len(active)}) [{tag}]:")
        print("\n".join(_fmt(active)))
    if strict_:
        tag = "● enforced" if strict else "○ not yet (refill still available)"
        print(f"strict/day-limit blocked ({len(strict_)}) [{tag}]:")
        print("\n".join(_fmt(strict_)))
    if schedule:
        print(f"schedule blocked ({len(schedule)}) [● window active now]:")
        print("\n".join(_fmt(schedule)))


def cmd_url(port=8642):
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        ip = s.getsockname()[0]
        s.close()
    except OSError:
        ip = "localhost"
    print(f"http://{ip}:{port}/")


def cmd_restart():
    subprocess.run(
        ["systemctl", "--user", "restart",
         "breaktimer-core.service", "breaktimer-ambient.service",
         "breaktimer-web.service"],
        check=True,
    )
    print("restarted")


argv = sys.argv[1:]
if not argv or argv[0] == "status":
    cmd_status()
elif argv[0] == "url":
    cmd_url()
elif argv[0] == "brightness" and len(argv) > 1 and argv[1] == "off":
    cmd_brightness_off(
        float(argv[2]) if len(argv) > 2 else 120.0,
        int(argv[3]) if len(argv) > 3 else 100,
    )
elif argv[0] == "brightness" and len(argv) > 1 and argv[1] == "on":
    cmd_brightness_on()
elif argv[0] == "blocklist":
    cmd_blocklist()
elif argv[0] == "restart":
    cmd_restart()
else:
    print(__doc__)
    sys.exit(1)
